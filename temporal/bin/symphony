#!/bin/bash

set -eu -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
readonly REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

export GOCACHE="${GOCACHE:-${REPO_ROOT}/.symphony/dev/go-build}"
export GOTMPDIR="${GOTMPDIR:-${REPO_ROOT}/.symphony/dev/go-tmp}"
export TMPDIR="${TMPDIR:-${GOTMPDIR}}"
mkdir -p "${GOCACHE}"
mkdir -p "${GOTMPDIR}"

cd "${REPO_ROOT}/temporal"
exec go run ./cmd/symphony "$@"
