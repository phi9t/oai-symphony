#!/bin/bash

set -eu -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
readonly K3S_ROOT="${SCRIPT_DIR}/.."

# shellcheck disable=SC1091
source "${K3S_ROOT}/lib/k3s-common.sh"

SUBCOMMAND=""
PROJECT_ID=""
JOB_NAME=""
NAMESPACE="symphony"
IMAGE="symphony/agent:latest"
CPU_REQUEST="2"
MEMORY_REQUEST="8Gi"
GPU_COUNT="0"
RUNTIME_CLASS=""
TTL_SECONDS_AFTER_FINISHED="86400"
PROJECT_ROOT=""
SHARED_CACHE_ROOT=""
OUTPUT="text"
JOB_COMMAND=""

usage() {
    cat <<'EOF'
Usage:
  sjob run --project-id <id> --job <name> --project-root <path> --shared-cache-root <path> [--namespace <ns>] [--image <image>] [--cpu <cpu>] [--memory <mem>] [--gpu-count <count>] [--runtime-class <name>] [--ttl-seconds-after-finished <seconds>] -- <command>
  sjob status --project-id <id> --job <name> [--namespace <ns>] [--output text|json]
  sjob stop --project-id <id> --job <name> [--namespace <ns>]
EOF
}

parse_args() {
    [[ $# -gt 0 ]] || { usage; exit 2; }
    SUBCOMMAND="$1"
    shift

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --project-id) PROJECT_ID="$2"; shift 2 ;;
            --job) JOB_NAME="$2"; shift 2 ;;
            --namespace) NAMESPACE="$2"; shift 2 ;;
            --image) IMAGE="$2"; shift 2 ;;
            --cpu) CPU_REQUEST="$2"; shift 2 ;;
            --memory) MEMORY_REQUEST="$2"; shift 2 ;;
            --gpu-count) GPU_COUNT="$2"; shift 2 ;;
            --runtime-class) RUNTIME_CLASS="$2"; shift 2 ;;
            --ttl-seconds-after-finished) TTL_SECONDS_AFTER_FINISHED="$2"; shift 2 ;;
            --project-root) PROJECT_ROOT="$2"; shift 2 ;;
            --shared-cache-root) SHARED_CACHE_ROOT="$2"; shift 2 ;;
            --output) OUTPUT="$2"; shift 2 ;;
            --) shift; JOB_COMMAND="$*"; break ;;
            *) echo "unknown option: $1" >&2; usage; exit 2 ;;
        esac
    done
}

job_resource_name() {
    printf 'symphony-job-%s-%s' "$(resource_project_id)" "$(resource_job_name)"
}

yaml_double_quote() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    printf '%s' "${value}"
}

validate_non_negative_integer() {
    local value="$1"
    [[ "${value}" =~ ^[0-9]+$ ]]
}

hash_suffix() {
    printf '%s' "$1" | cksum | awk '{print $1}' | cut -c1-8
}

sanitize_name_component() {
    local value="$1"
    local max_length="$2"
    local checksum=""
    local keep=0

    value="$(printf '%s' "${value}" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
    [[ -n "${value}" ]] || value="run"

    if (( ${#value} > max_length )); then
        checksum="$(hash_suffix "${value}")"
        keep=$((max_length - ${#checksum} - 1))
        if (( keep < 1 )); then
            value="${checksum:0:max_length}"
        else
            value="${value:0:keep}"
            value="${value%-}"
            value="${value}-${checksum}"
        fi
    fi

    printf '%s' "${value}"
}

resource_project_id() {
    sanitize_name_component "${PROJECT_ID}" 20
}

resource_job_name() {
    sanitize_name_component "${JOB_NAME}" 28
}

require_absolute_path() {
    local path_value="$1"
    local flag_name="$2"

    [[ "${path_value}" = /* ]] || die "${flag_name} must be an absolute path"
}

ensure_writable_dir() {
    local dir_path="$1"
    local probe_path="${dir_path}/.symphony-write-test-$$"

    mkdir -p "${dir_path}"
    : > "${probe_path}" || die "path not writable: ${dir_path}"
    rm -f "${probe_path}"
}

validate_run_paths() {
    require_absolute_path "${PROJECT_ROOT}" "--project-root"
    require_absolute_path "${SHARED_CACHE_ROOT}" "--shared-cache-root"

    ensure_writable_dir "${PROJECT_ROOT}/home"
    ensure_writable_dir "${PROJECT_ROOT}/config"
    ensure_writable_dir "${PROJECT_ROOT}/workspace"
    ensure_writable_dir "${PROJECT_ROOT}/outputs"
    ensure_writable_dir "${SHARED_CACHE_ROOT}"
}

prepare_manifest_vars() {
    RUNTIME_CLASS_BLOCK=""
    GPU_REQUEST_BLOCK=""
    GPU_LIMIT_BLOCK=""
    RESOURCE_PROJECT_ID="$(resource_project_id)"
    RESOURCE_JOB_NAME="$(resource_job_name)"
    RESOURCE_NAME="$(job_resource_name)"

    if [[ -n "${RUNTIME_CLASS}" ]]; then
        local escaped_runtime_class
        escaped_runtime_class="$(yaml_double_quote "${RUNTIME_CLASS}")"
        # shellcheck disable=SC2089
        printf -v RUNTIME_CLASS_BLOCK '\n      runtimeClassName: "%s"' "${escaped_runtime_class}"
    fi

    if [[ "${GPU_COUNT}" != "0" ]]; then
        # shellcheck disable=SC2089
        printf -v GPU_REQUEST_BLOCK '\n              nvidia.com/gpu: "%s"' "${GPU_COUNT}"
        # shellcheck disable=SC2089
        printf -v GPU_LIMIT_BLOCK '\n              nvidia.com/gpu: "%s"' "${GPU_COUNT}"
    fi

    # shellcheck disable=SC2090
    export RUNTIME_CLASS_BLOCK GPU_REQUEST_BLOCK GPU_LIMIT_BLOCK RESOURCE_PROJECT_ID RESOURCE_JOB_NAME RESOURCE_NAME
}

status_json() {
    local status="$1"
    printf '{"status":"%s","jobName":"%s"}\n' "${status}" "$(job_resource_name)"
}

cmd_run() {
    [[ -n "${PROJECT_ID}" && -n "${JOB_NAME}" && -n "${PROJECT_ROOT}" && -n "${SHARED_CACHE_ROOT}" ]] || die "project-id, job, project-root, and shared-cache-root are required"
    [[ -n "${JOB_COMMAND}" ]] || die "missing job command"
    validate_non_negative_integer "${GPU_COUNT}" || die "gpu-count must be a non-negative integer"

    ensure_dirs "${PROJECT_ROOT}"
    validate_run_paths
    check_kubectl
    check_envsubst

    REPO_ROOT="$(cd "${K3S_ROOT}/.." && pwd)"
    prepare_manifest_vars
    export PROJECT_ID JOB_NAME NAMESPACE IMAGE CPU_REQUEST MEMORY_REQUEST GPU_COUNT RUNTIME_CLASS TTL_SECONDS_AFTER_FINISHED JOB_COMMAND PROJECT_ROOT SHARED_CACHE_ROOT REPO_ROOT
    export REPO_ROOT

    envsubst < "${K3S_ROOT}/templates/job.yaml" | kubectl_cmd apply -f -
    log "submitted $(job_resource_name)"
}

cmd_status() {
    [[ -n "${PROJECT_ID}" && -n "${JOB_NAME}" ]] || die "project-id and job are required"
    check_kubectl

    local resource_name
    resource_name="$(job_resource_name)"

    if ! kubectl_cmd get job -n "${NAMESPACE}" "${resource_name}" >/dev/null 2>&1; then
        if [[ "${OUTPUT}" == "json" ]]; then
            status_json "missing"
        else
            echo "missing"
        fi
        return 0
    fi

    local succeeded
    succeeded="$(kubectl_cmd get job -n "${NAMESPACE}" "${resource_name}" -o jsonpath='{.status.succeeded}' 2>/dev/null || true)"
    local failed
    failed="$(kubectl_cmd get job -n "${NAMESPACE}" "${resource_name}" -o jsonpath='{.status.failed}' 2>/dev/null || true)"

    local status="running"
    if [[ "${succeeded}" == "1" ]]; then
        status="succeeded"
    elif [[ "${failed}" != "" && "${failed}" != "0" ]]; then
        status="failed"
    fi

    if [[ "${OUTPUT}" == "json" ]]; then
        status_json "${status}"
    else
        echo "${status}"
    fi
}

cmd_stop() {
    [[ -n "${PROJECT_ID}" && -n "${JOB_NAME}" ]] || die "project-id and job are required"
    check_kubectl
    kubectl_cmd delete job -n "${NAMESPACE}" "$(job_resource_name)" --ignore-not-found=true >/dev/null
    log "deleted $(job_resource_name)"
}

parse_args "$@"

case "${SUBCOMMAND}" in
    run) cmd_run ;;
    status) cmd_status ;;
    stop) cmd_stop ;;
    *) usage; exit 2 ;;
esac
