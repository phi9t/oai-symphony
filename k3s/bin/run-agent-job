#!/bin/bash

set -eu -o pipefail

: "${PROMPT_PATH:?PROMPT_PATH is required}"
: "${WORKPAD_PATH:?WORKPAD_PATH is required}"
: "${RESULT_PATH:?RESULT_PATH is required}"
: "${REPOSITORY_ORIGIN_URL:?REPOSITORY_ORIGIN_URL is required}"
: "${REPOSITORY_DEFAULT_BRANCH:=main}"
: "${WORKSPACE_PATH:?WORKSPACE_PATH is required}"
: "${CODEX_COMMAND:=codex exec --full-auto --json}"

mkdir -p "$(dirname "${WORKPAD_PATH}")"
mkdir -p "$(dirname "${RESULT_PATH}")"
mkdir -p "${WORKSPACE_PATH}"

git config --global --add safe.directory "${WORKSPACE_PATH}" >/dev/null 2>&1 || true

if [[ -d "${REPOSITORY_ORIGIN_URL}" ]]; then
    git config --global --add safe.directory "${REPOSITORY_ORIGIN_URL}" >/dev/null 2>&1 || true
    git config --global --add safe.directory "${REPOSITORY_ORIGIN_URL}/.git" >/dev/null 2>&1 || true
fi

if [[ ! -d "${WORKSPACE_PATH}/.git" ]]; then
    GIT_CONFIG_COUNT=1 \
    GIT_CONFIG_KEY_0=init.defaultBranch \
    GIT_CONFIG_VALUE_0="${REPOSITORY_DEFAULT_BRANCH}" \
    git -C "${WORKSPACE_PATH}" init >/dev/null

    if git -C "${WORKSPACE_PATH}" remote get-url origin >/dev/null 2>&1; then
        git -C "${WORKSPACE_PATH}" remote set-url origin "${REPOSITORY_ORIGIN_URL}"
    else
        git -C "${WORKSPACE_PATH}" remote add origin "${REPOSITORY_ORIGIN_URL}"
    fi

    git -C "${WORKSPACE_PATH}" fetch origin "${REPOSITORY_DEFAULT_BRANCH}" --depth 1
    git -C "${WORKSPACE_PATH}" checkout -B "${REPOSITORY_DEFAULT_BRANCH}" FETCH_HEAD
else
    git -C "${WORKSPACE_PATH}" fetch origin "${REPOSITORY_DEFAULT_BRANCH}" --depth 1 || true
fi

if [[ ! -f "${WORKPAD_PATH}" ]]; then
    cat > "${WORKPAD_PATH}" <<'EOF'
### Environment
`<host>:<abs-workdir>@<unknown-sha>`

### Plan
- [ ] Update this plan before making changes

### Acceptance Criteria
- [ ] Record acceptance criteria here

### Validation
- [ ] Record validation here

### Notes
- Created by run-agent-job
EOF
fi

cd "${WORKSPACE_PATH}"

export PROMPT_CONTENT="$(cat "${PROMPT_PATH}")"

set +e
sh -lc "${CODEX_COMMAND} \"\$PROMPT_CONTENT\"" > ".symphony/codex-output.jsonl" 2>&1
status=$?
set -e

if [[ ! -f "${RESULT_PATH}" ]]; then
    if [[ ${status} -eq 0 ]]; then
        target_state="Human Review"
        blocked_reason="null"
    else
        target_state="Rework"
        blocked_reason="\"codex command failed with exit ${status}\""
    fi

    cat > "${RESULT_PATH}" <<EOF
{"status":"$( [[ ${status} -eq 0 ]] && echo succeeded || echo failed )","targetState":"${target_state}","summary":"Codex run completed with exit ${status}.","validation":[],"blockedReason":${blocked_reason},"needsContinuation":false}
EOF
fi

exit ${status}
