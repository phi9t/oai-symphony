#!/bin/bash

set -eu -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
readonly REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
readonly STATE_ROOT="${REPO_ROOT}/.symphony/dev/temporal-k3s"
readonly LOG_ROOT="${STATE_ROOT}/logs"
readonly WORKER_PID_FILE="${STATE_ROOT}/worker.pid"
readonly WORKER_LOG="${LOG_ROOT}/worker.log"
readonly KUBECTL_WRAPPER="${REPO_ROOT}/k3s/bin/docker-kubectl"

TEMPORAL_CONTAINER_NAME="${SYMPHONY_TEMPORAL_CONTAINER_NAME:-symphony-temporal-dev}"
K3S_CONTAINER_NAME="${SYMPHONY_K3S_CONTAINER_NAME:-symphony-k3s-dev}"
PROJECT_ROOT="${SYMPHONY_K3S_PROJECT_ROOT:-${REPO_ROOT}/.symphony/dev/projects}"
SHARED_CACHE_ROOT="${SYMPHONY_K3S_SHARED_CACHE_ROOT:-${REPO_ROOT}/.symphony/dev/shared-cache}"
SMOKE_IMAGE="${SYMPHONY_SMOKE_IMAGE:-symphony/smoke-agent:dev}"
TEMPORAL_ADDRESS="${TEMPORAL_ADDRESS:-127.0.0.1:7233}"
TEMPORAL_NAMESPACE="${TEMPORAL_NAMESPACE:-default}"
TEMPORAL_TASK_QUEUE="${TEMPORAL_TASK_QUEUE:-symphony}"
K3S_NAMESPACE="${SYMPHONY_K3S_NAMESPACE:-symphony}"
TEMPORAL_SERVER_IMAGE="${SYMPHONY_TEMPORAL_SERVER_IMAGE:-temporalio/server}"
K3S_SERVER_IMAGE="${SYMPHONY_K3S_SERVER_IMAGE:-rancher/k3s}"
SMOKE_TIMEOUT_SECONDS="${SYMPHONY_SMOKE_TIMEOUT_SECONDS:-180}"
K3S_API_PORT="${SYMPHONY_K3S_API_PORT:-6445}"

usage() {
    cat <<'EOF'
Usage:
  ./dev/temporal-k3s up
  ./dev/temporal-k3s status
  ./dev/temporal-k3s smoke
  ./dev/temporal-k3s down
  ./dev/temporal-k3s env
EOF
}

log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] [dev/temporal-k3s] $*" >&2
}

die() {
    log "FATAL: $*"
    exit 1
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || die "$1 not found"
}

ensure_dirs() {
    mkdir -p "${STATE_ROOT}" "${LOG_ROOT}" "${PROJECT_ROOT}" "${SHARED_CACHE_ROOT}"
}

docker_ready() {
    docker info >/dev/null 2>&1
}

container_exists() {
    docker container inspect "$1" >/dev/null 2>&1
}

container_running() {
    [[ "$(docker inspect -f '{{.State.Running}}' "$1" 2>/dev/null || echo false)" == "true" ]]
}

worker_running() {
    [[ -f "${WORKER_PID_FILE}" ]] || return 1
    kill -0 "$(cat "${WORKER_PID_FILE}")" >/dev/null 2>&1
}

stop_worker() {
    if worker_running; then
        kill "$(cat "${WORKER_PID_FILE}")" >/dev/null 2>&1 || true
        wait "$(cat "${WORKER_PID_FILE}")" 2>/dev/null || true
    fi

    rm -f "${WORKER_PID_FILE}"
}

with_dev_kubectl() {
    SYMPHONY_K3S_CONTAINER_NAME="${K3S_CONTAINER_NAME}" "${KUBECTL_WRAPPER}" "$@"
}

temporal_host() {
    echo "${TEMPORAL_ADDRESS%%:*}"
}

temporal_port() {
    echo "${TEMPORAL_ADDRESS##*:}"
}

wait_for_tcp() {
    local host="$1"
    local port="$2"
    local timeout_seconds="$3"
    local deadline=$((SECONDS + timeout_seconds))

    while ((SECONDS < deadline)); do
        if bash -lc "exec 3<>/dev/tcp/${host}/${port}" >/dev/null 2>&1; then
            return 0
        fi
        sleep 1
    done

    return 1
}

wait_for_k3s() {
    local deadline=$((SECONDS + 60))

    while ((SECONDS < deadline)); do
        if with_dev_kubectl get nodes >/dev/null 2>&1; then
            return 0
        fi
        sleep 2
    done

    return 1
}

wait_for_worker() {
    local deadline=$((SECONDS + 30))

    while ((SECONDS < deadline)); do
        if grep -q "worker started" "${WORKER_LOG}" 2>/dev/null; then
            return 0
        fi

        if ! worker_running; then
            return 1
        fi

        sleep 1
    done

    return 1
}

start_temporal_container() {
    if container_running "${TEMPORAL_CONTAINER_NAME}"; then
        log "Temporal container already running: ${TEMPORAL_CONTAINER_NAME}"
    else
        if container_exists "${TEMPORAL_CONTAINER_NAME}"; then
            docker rm -f "${TEMPORAL_CONTAINER_NAME}" >/dev/null
        fi

        docker run -d \
            --name "${TEMPORAL_CONTAINER_NAME}" \
            -p "$(temporal_host):$(temporal_port):7233" \
            "${TEMPORAL_SERVER_IMAGE}" \
            server start-dev --ip 0.0.0.0 --namespace "${TEMPORAL_NAMESPACE}" >/dev/null
        log "Started Temporal container ${TEMPORAL_CONTAINER_NAME}"
    fi

    wait_for_tcp "$(temporal_host)" "$(temporal_port)" 60 || die "Temporal did not become ready"
}

start_k3s_container() {
    if container_running "${K3S_CONTAINER_NAME}"; then
        log "K3s container already running: ${K3S_CONTAINER_NAME}"
    else
        if container_exists "${K3S_CONTAINER_NAME}"; then
            docker rm -f "${K3S_CONTAINER_NAME}" >/dev/null
        fi

        docker run -d \
            --name "${K3S_CONTAINER_NAME}" \
            --privileged \
            -p "127.0.0.1:${K3S_API_PORT}:6443" \
            -v "${REPO_ROOT}:${REPO_ROOT}" \
            -v "${PROJECT_ROOT}:${PROJECT_ROOT}" \
            -v "${SHARED_CACHE_ROOT}:${SHARED_CACHE_ROOT}" \
            "${K3S_SERVER_IMAGE}" \
            server --disable=traefik --write-kubeconfig-mode=644 >/dev/null
        log "Started K3s container ${K3S_CONTAINER_NAME}"
    fi

    wait_for_k3s || die "K3s did not become ready"
    with_dev_kubectl apply -f "${REPO_ROOT}/k3s/manifests/namespace.yaml" >/dev/null
}

build_smoke_image() {
    docker build -t "${SMOKE_IMAGE}" -f "${REPO_ROOT}/k3s/Dockerfile.smoke-agent" "${REPO_ROOT}" >/dev/null
    log "Built smoke agent image ${SMOKE_IMAGE}"
}

import_smoke_image() {
    docker save "${SMOKE_IMAGE}" | docker exec -i "${K3S_CONTAINER_NAME}" k3s ctr images import - >/dev/null
    log "Imported smoke agent image into ${K3S_CONTAINER_NAME}"
}

start_worker() {
    if worker_running; then
        log "Temporal worker already running with pid $(cat "${WORKER_PID_FILE}")"
        return 0
    fi

    rm -f "${WORKER_PID_FILE}"

    (
        cd "${REPO_ROOT}"
        export TEMPORAL_ADDRESS TEMPORAL_NAMESPACE TEMPORAL_TASK_QUEUE
        export SYMPHONY_KUBECTL_WRAPPER="${KUBECTL_WRAPPER}"
        export SYMPHONY_K3S_CONTAINER_NAME="${K3S_CONTAINER_NAME}"
        nohup ./temporal/bin/worker >"${WORKER_LOG}" 2>&1 &
        echo $! > "${WORKER_PID_FILE}"
    )

    wait_for_worker || die "Temporal worker exited before becoming ready; see ${WORKER_LOG}"
}

cmd_up() {
    require_command docker
    require_command envsubst
    require_command git
    require_command go
    docker_ready || die "docker daemon not reachable"
    ensure_dirs

    start_temporal_container
    start_k3s_container
    build_smoke_image
    import_smoke_image
    start_worker

    cmd_status
}

cmd_status() {
    require_command docker

    local temporal_state="stopped"
    local k3s_state="stopped"
    local worker_state="stopped"
    local namespace_state="missing"

    if container_running "${TEMPORAL_CONTAINER_NAME}" && wait_for_tcp "$(temporal_host)" "$(temporal_port)" 1; then
        temporal_state="ready"
    fi

    if container_running "${K3S_CONTAINER_NAME}" && with_dev_kubectl get nodes >/dev/null 2>&1; then
        k3s_state="ready"
        if with_dev_kubectl get namespace "${K3S_NAMESPACE}" >/dev/null 2>&1; then
            namespace_state="ready"
        fi
    fi

    if worker_running; then
        worker_state="ready"
    fi

    printf 'temporal: %s\n' "${temporal_state}"
    printf 'k3s: %s\n' "${k3s_state}"
    printf 'worker: %s\n' "${worker_state}"
    printf 'namespace: %s\n' "${namespace_state}"

    [[ "${temporal_state}" == "ready" && "${k3s_state}" == "ready" && "${worker_state}" == "ready" && "${namespace_state}" == "ready" ]]
}

cmd_env() {
    printf 'export TEMPORAL_ADDRESS=%q\n' "${TEMPORAL_ADDRESS}"
    printf 'export TEMPORAL_NAMESPACE=%q\n' "${TEMPORAL_NAMESPACE}"
    printf 'export TEMPORAL_TASK_QUEUE=%q\n' "${TEMPORAL_TASK_QUEUE}"
    printf 'export SYMPHONY_K3S_PROJECT_ROOT=%q\n' "${PROJECT_ROOT}"
    printf 'export SYMPHONY_K3S_SHARED_CACHE_ROOT=%q\n' "${SHARED_CACHE_ROOT}"
}

cmd_smoke() {
    cmd_up >/dev/null

    local smoke_id="smoke-$(date +%Y%m%d%H%M%S)"
    local smoke_root="${PROJECT_ROOT}/${smoke_id}"
    local workspace_path="${smoke_root}/workspace"
    local outputs_path="${smoke_root}/outputs"
    local symphony_path="${workspace_path}/.symphony"
    local prompt_path="${symphony_path}/prompt.md"
    local workpad_path="${symphony_path}/workpad.md"
    local result_path="${symphony_path}/run-result.json"
    local issue_path="${symphony_path}/issue.json"
    local input_path
    local status_input_path
    local workflow_id="smoke/${smoke_id}"

    mkdir -p "${symphony_path}" "${outputs_path}"

    cat > "${prompt_path}" <<EOF
Temporal/K3s smoke workflow for ${smoke_id}.
Write the required Symphony artifacts and exit successfully.
EOF

    cat > "${workpad_path}" <<'EOF'
### Environment
`pending`

### Plan
- [ ] Start smoke workflow

### Acceptance Criteria
- [ ] Smoke workflow completes

### Validation
- [ ] ./dev/temporal-k3s smoke

### Notes
- Created by ./dev/temporal-k3s smoke
EOF

    cat > "${issue_path}" <<EOF
{"id":"${smoke_id}","identifier":"${smoke_id}","title":"Temporal/K3s smoke","state":"In Progress"}
EOF

    input_path="$(mktemp)"
    status_input_path="$(mktemp)"
    trap 'rm -f "${input_path}" "${status_input_path}"' EXIT

    cat > "${input_path}" <<EOF
{
  "workflowId": "${workflow_id}",
  "projectId": "${smoke_id}",
  "repository": {
    "originUrl": "/opt/symphony",
    "defaultBranch": "main"
  },
  "codex": {
    "command": "python3 /opt/symphony/dev/smoke_codex.py"
  },
  "temporal": {
    "address": "${TEMPORAL_ADDRESS}",
    "namespace": "${TEMPORAL_NAMESPACE}",
    "taskQueue": "${TEMPORAL_TASK_QUEUE}"
  },
  "k3s": {
    "namespace": "${K3S_NAMESPACE}",
    "image": "${SMOKE_IMAGE}",
    "projectRoot": "${smoke_root}",
    "sharedCacheRoot": "${SHARED_CACHE_ROOT}",
    "ttlSecondsAfterFinished": 300,
    "defaultCPU": "1",
    "defaultMemory": "1Gi",
    "defaultGPUCount": 0,
    "runtimeClass": ""
  },
  "issue": {
    "id": "${smoke_id}",
    "identifier": "${smoke_id}",
    "title": "Temporal/K3s smoke",
    "state": "In Progress"
  },
  "paths": {
    "projectRoot": "${smoke_root}",
    "workspacePath": "${workspace_path}",
    "outputsPath": "${outputs_path}",
    "promptPath": "${prompt_path}",
    "workpadPath": "${workpad_path}",
    "resultPath": "${result_path}",
    "issuePath": "${issue_path}"
  }
}
EOF

    printf '%s\n' "$("${REPO_ROOT}/temporal/bin/symphony" run --input "${input_path}" --output json)"

    cat > "${status_input_path}" <<EOF
{"workflowId":"${workflow_id}"}
EOF

    local deadline=$((SECONDS + SMOKE_TIMEOUT_SECONDS))
    local status_output=""

    while ((SECONDS < deadline)); do
        status_output="$("${REPO_ROOT}/temporal/bin/symphony" status --input "${status_input_path}" --output json)"

        case "${status_output}" in
            *'"status":"succeeded"'*)
                break
                ;;
            *'"status":"failed"'* | *'"status":"cancelled"'*)
                die "Smoke workflow ended unsuccessfully: ${status_output}"
                ;;
        esac

        sleep 3
    done

    if ((SECONDS >= deadline)); then
        die "Smoke workflow timed out after ${SMOKE_TIMEOUT_SECONDS}s"
    fi

    [[ -f "${result_path}" ]] || die "Smoke workflow did not write ${result_path}"
    grep -Eq '"status"[[:space:]]*:[[:space:]]*"succeeded"' "${result_path}" || die "Smoke result did not report success"
    grep -Eq '"targetState"[[:space:]]*:[[:space:]]*"Human Review"' "${result_path}" || die "Smoke result did not set Human Review"
    grep -q "Smoke workflow completed" "${workpad_path}" || die "Smoke workpad was not updated"

    log "Smoke workflow succeeded"
    printf 'artifacts: %s\n' "${symphony_path}"
}

cmd_down() {
    require_command docker

    stop_worker

    if container_exists "${K3S_CONTAINER_NAME}"; then
        docker rm -f "${K3S_CONTAINER_NAME}" >/dev/null
        log "Removed ${K3S_CONTAINER_NAME}"
    fi

    if container_exists "${TEMPORAL_CONTAINER_NAME}"; then
        docker rm -f "${TEMPORAL_CONTAINER_NAME}" >/dev/null
        log "Removed ${TEMPORAL_CONTAINER_NAME}"
    fi
}

subcommand="${1:-}"

case "${subcommand}" in
    up)
        cmd_up
        ;;
    status)
        cmd_status
        ;;
    smoke)
        cmd_smoke
        ;;
    down)
        cmd_down
        ;;
    env)
        cmd_env
        ;;
    "" | help | --help | -h)
        usage
        ;;
    *)
        usage
        exit 2
        ;;
esac
